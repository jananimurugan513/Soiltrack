{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "url", "description": "User's photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "CropPlan": {
      "title": "Crop Plan",
      "description": "Stores AI-generated crop plans for users",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's user ID" },
        "soilData": { "type": "object", "description": "Input soil data" },
        "recommendations": { "type": "array", "description": "List of recommended crops" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "soilData", "recommendations", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/users/{userId}/cropPlans/{planId}": {
      "schema": "CropPlan",
      "description": "User's saved crop plans"
    }
  }
}
